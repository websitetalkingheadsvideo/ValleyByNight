{
  "mcpServers": {
    "laws-agent": {
      "command": "node",
      "args": [
        "V:\\agents\\laws_agent\\scripts\\mcp_laws_agent_v2.js"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}",
        "ANTHROPIC_MODEL": "${env:ANTHROPIC_MODEL}",
        "DB_HOST": "${env:DB_HOST}",
        "DB_USER": "${env:DB_USER}",
        "DB_PASS": "${env:DB_PASS}",
        "DB_NAME": "${env:DB_NAME}",
        "LAWS_AGENT_URL": "http://192.168.0.155/"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${env:CONTEXT7_API_KEY}"
      }
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "character-agent": {
      "command": "php",
      "args": [
        "V:\\agents/character_agent/server.php"
      ]
    },
    "style-agent": {
      "command": "php",
      "args": [
        "V:\\agents\\style_agent\\server.php"
      ]
    }
  }
}