    "runtime_contract": {
        "mix_profile_active_ref": "mix_default",
        "focus_drives_foreground": true,
        "location_underbed_persists": true,
        "presence_does_not_steal_focus": true,
        "state_inputs": {
            "location_ref": "location:<id>",
            "focus_ref": "character|creature|object|location:<id>",
            "presence_refs": [
                "optional array"
            ],
            "events": [
                "fire-and-forget event keys (e.g., combat_start, puzzle_solved_reward_ui, cinematic_intro_start)"
            ]
        },
        "resolution_rules": [
            "Always ensure location_underbed for current location is playing at underbed gain.",
            "If focus_ref changes and has a matching focus_bed cue, crossfade foreground bed to that cue.",
            "Presence can trigger stingers but does not replace foreground bed unless focus changes.",
            "Exclusive override cues stop/duck other music per override settings, then resume per resume_mode.",
            "Cinematic intro overrides have highest priority (200), exclusive mode. After intro ends, handoff to location ambient or NPC leitmotif based on current context.",
            "NPC focus acquired (on_focus_acquired) should crossfade foreground bed, but location underbed persists.",
            "NPC focus lost (on_focus_lost) should return to location ambient only (no foreground bed)."
        ]
    }
