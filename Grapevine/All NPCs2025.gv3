  <item name="Snake Oil" type="Talisman" subtype="Draba" level="0" bonus="2" amount="0" conceal="None" lastmodified="1/25/2004 5:29:01 AM">
    <traitlist name="Tempers" abc="yes" display="2">
      <trait name="Power" val="3"/>
