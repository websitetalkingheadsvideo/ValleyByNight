    </notes>
  </item>
  <item name="Torc of the Fianna" type="Fetish" subtype="Torc (Necklace)" level="0" bonus="0" damage="N/A" amount="0" conceal="High Necked Shirt" lastmodified="3/27/2003 12:48:48 AM">
    <traitlist name="Tempers" abc="yes" display="2"/>
    <traitlist name="Abilities" abc="yes" display="1">
      <trait name="Cold Iron"/>
    </traitlist>
    <traitlist name="Negatives" abc="yes" negative="yes" display="1">
      <trait name="Fragile"/>
    </traitlist>
    <traitlist name="Availability" abc="yes" display="1">
      <trait name="Unique" note="Special Gift from the Telyavs"/>
    </traitlist>
    <powers>
      <![CDATA[Registers the individual wearing the necklace as human to any Wyrm Sensing powers. (IE Person does not have Wyrm Taint & is considered Human by Garou)
Also has a limitation placed on it that those wearing it will be as vunerable to silver as Garou are.]]>
    </powers>
    <appearance>
      <![CDATA[A wrought iron torc, it has 5 cainines hanging from the front, and a single piece of petrified Rowan wood, with the message "Fianna's Favor" written in Ogham.]]>
    </appearance>
    <notes>
      <![CDATA[Smithed by the Fianna, and enchanted by the now dead Telyavs.  Has 1 cainine of each rank of the Fianna Tribe. (5 Total)]]>
    </notes>
  </item>
