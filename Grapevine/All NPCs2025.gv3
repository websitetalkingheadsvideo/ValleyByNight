  <item name="Tent, Camping" type="Equipment" level="0" bonus="0" amount="0" conceal="None" lastmodified="1/23/2004 4:39:12 PM">
    <traitlist name="Tempers" abc="yes" display="2"/>
    <traitlist name="Abilities" abc="yes" display="1"/>
    <traitlist name="Negatives" abc="yes" negative="yes" display="1">
      <trait name="Clumsy"/>
      <trait name="Heavy"/>
    </traitlist>
    <traitlist name="Availability" abc="yes" display="1">
      <trait name="Any"/>
    </traitlist>
    <powers>
      <![CDATA[Prevents owner from getting wet when raining if tent has been setup.  Setup requires Mental Challenge versus 6 traits.]]>
    </powers>
    <appearance>
      <![CDATA[Standard canvas two person tent. Zippered front and windows.]]>
    </appearance>
    <notes>
