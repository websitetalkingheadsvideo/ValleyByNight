  <item name="Paris' Staff" type="Magic Item" subtype="Weapon" level="5" bonus="2" damage="Lethal" amount="2" conceal="None" lastmodified="10/29/2003 2:28:12 AM">
    <traitlist name="Tempers" abc="yes" display="2"/>
