  <item name="Chalice" type="Equipment" subtype="Relic" level="0" bonus="0" damage="None" amount="0" conceal="Briefcase" lastmodified="4/14/2007 8:15:44 PM">
    <traitlist name="Tempers" abc="yes" display="2">
