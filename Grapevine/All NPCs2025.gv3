  <item name="Stun Baton" type="Equipment" subtype="Weapon" level="0" bonus="2" damage="Lethal" amount="1" conceal="Trenchcoat" lastmodified="3/19/2003 1:45:13 AM">
    <traitlist name="Tempers" abc="yes" display="2"/>
    <traitlist name="Abilities" abc="yes" display="1"/>
    <traitlist name="Negatives" abc="yes" negative="yes" display="1">
      <trait name="Clumsy"/>
    </traitlist>
    <traitlist name="Availability" abc="yes" display="1"/>
    <powers>
      <![CDATA[Stun: On a successful hit, the target suffers from the Negative Physical Trait: Clumsy and the negative Mental Trait: Witless.  These negative traits are cumulative.  Once the character reaches Clumsy x2 and Witless x2, the character is considered Incapacitated and loses their next action (not full turn- characters with Celerity may very well get up within the same turn).  These negative traits are temporary and lost at the rate of one Clumsy and one Witless per subsequent action (not full turn- characters with high enough (Elder level) Celerity may very well recover within the turn).]]>
    </powers>
  </item>
  <item name="Stun Gun" type="Equipment" subtype="Weapon" level="0" bonus="2" damage="Bashing" amount="1" conceal="Pocket" lastmodified="1/25/2004 7:06:05 AM">
