  <item name="Taser Air Gun" type="Equipment" subtype="Ranged Weapon" level="0" bonus="2" damage="Bashing" amount="1" conceal="Jacket" lastmodified="1/25/2004 7:05:21 AM">
    <traitlist name="Tempers" abc="yes" display="2">
      <trait name="Rounds/Ammunition"/>
    </traitlist>
    <traitlist name="Abilities" abc="yes" display="1">
      <trait name="Incapacitation"/>
    </traitlist>
    <traitlist name="Negatives" abc="yes" negative="yes" display="1">
      <trait name="Fragile"/>
    </traitlist>
    <traitlist name="Availability" abc="yes" display="1">
      <trait name="Any"/>
    </traitlist>
    <powers>
      <![CDATA[Incapacitation: On a successful hit, the target is considered Incapacitated for 5 minutes and gains the Negative Physical Trait: Clumsy x2 and the negative Mental Trait: Witless x2.  These negative traits are temporary and lost at the rate of one Clumsy and one Witless per subsequent action after the 5 minutes (not full turn- characters with high enough (Elder level) Celerity may very well recover within the turn).]]>
    </powers>
    <appearance>
      <![CDATA[Standard CO2 propelled taser.  The weapon fires two small barbs at the target then transmits an electrical charge through the wires into the target for 5 minutes (unless turned off or the barbs are removed from the target (Static Physical against 3 traits)]]>
    </appearance>
    <notes>
