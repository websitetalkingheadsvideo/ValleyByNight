  <item name="Paris' Great Sword" type="Magic Item" subtype="Weapon" level="0" bonus="6" damage="4 Lethal (+1 vs Kindred and Wraiths)" amount="4" conceal="None" lastmodified="5/28/2003 10:54:07 PM">
