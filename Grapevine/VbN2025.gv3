    <traitlist name="Availability" abc="yes" display="1">
      <trait name="Unique"/>
    </traitlist>
    <powers>
      <![CDATA[When a necromancer breaks the fingerbone, they enter the shadowlands at the end of the turn.  They may not take anyone with them]]>
    </powers>
  </item>
